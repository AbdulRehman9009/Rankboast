generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?    
  role          Role      @default(USER) 
  subscription  Tier      @default(FREE) 
  siteUrl       String?
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  analysis      Analysis[]
  competitors   Competitor[]
  reports       Report[]
  resetTokens   PasswordResetToken[]
  generated     GeneratedContent[]
  projects      Project[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum Tier {
  FREE
  PREMIUM
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model Analysis {
  id           String   @id @default(cuid())
  userId       String
  url          String?  
  title        String
  content      String?  @db.Text
  seoScore     Int      @default(0) // 0-100 scale [cite: 562]
  resultsJson  Json     // Stores categorized metrics and recommendations [cite: 606]
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Competitor {
  id            String   @id @default(cuid())
  userId        String
  userUrl       String?
  competitorUrl String
  metricsJson   Json     // Stores competitor SEO data [cite: 606]
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  type        String   // PDF, CSV, etc. [cite: 606]
  filePath    String   // Path to exported file [cite: 606]
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model GeneratedContent {
  id              String   @id @default(cuid())
  userId          String
  topic           String
  keywords        String   
  keywordsUsed    String[] 
  tone            String
  audience        String
  wordCount       Int
  
  seoTitle        String   @db.VarChar(255)
  metaDescription String   @db.Text
  articleBody     String   @db.Text 
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        String   @id @default(cuid())
  domain    String   
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages     Page[]
  createdAt DateTime @default(now())

  @@unique([userId, domain])
}

model Page {
  id               String   @id @default(cuid())
  url              String
  title            String?
  contentSnippet   String?  @db.Text
  outgoingLinks    Page[]   @relation("PageLinks")
  incomingLinks    Page[]   @relation("PageLinks")
  aiLinkSuggestion String?  @db.Text 
  isOrphan         Boolean  @default(false)
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([projectId, url])
}